<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screenBackground">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorPrimary"
            app:title="🎓 Student Grade Calculator"
            app:titleTextColor="@android:color/white"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- MAIN SCROLLABLE CONTENT-->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- PROGRESS BAR  -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:indeterminate="true"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                android:progressTint="@color/colorAccent" />

            <!-- STUDENT COUNT BADGE  -->
            <TextView
                android:id="@+id/tvStudentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total students: 0"
                android:textColor="@color/textSecondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- CARD 1 — IMPORT FROM EXCEL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cardStroke"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📂  Import from Excel"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your .xlsx file must have two columns:\n  Column A → Student Name\n  Column B → Mark (0 – 100)\n  Row 1 is treated as a header and skipped."
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnImport"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Choose Excel File (.xlsx)"
                        app:icon="@drawable/ic_upload"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/colorPrimary" />

                    <!-- Filename shown after import -->
                    <TextView
                        android:id="@+id/tvFileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_file_selected"
                        android:textSize="12sp"
                        android:textColor="@color/colorSuccess"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2 — MANUAL ENTRY-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cardStroke"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️  Add Student Manually"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="14dp" />

                    <!-- Name input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Student Name"
                        app:startIconDrawable="@drawable/ic_person"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStudentName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:imeOptions="actionNext"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mark input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMark"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mark (0 – 100)"
                        app:startIconDrawable="@drawable/ic_grade"
                        app:suffixText="/100"
                        android:layout_marginBottom="14dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStudentMark"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:imeOptions="actionDone"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdd"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Add Student"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/colorSecondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ACTION BUTTONS ROW-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Calculate -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Calculate"
                    android:enabled="false"
                    app:icon="@drawable/ic_calculate"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/colorAccent"
                    android:layout_marginEnd="6dp" />

                <!-- Export -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Export"
                    android:enabled="false"
                    app:icon="@drawable/ic_download"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/colorSuccess"
                    android:layout_marginEnd="6dp" />

                <!-- Clear -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="Clear"
                    android:enabled="false"
                    app:icon="@drawable/ic_delete"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/colorError" />

            </LinearLayout>

            <!-- STATISTICS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cardStroke"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊  Class Statistics"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="12dp" />

                    <!-- Two-column stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView android:id="@+id/tvStatAverage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Average: —"
                                android:textColor="@color/textPrimary"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tvStatHighest"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Highest: —"
                                android:textColor="@color/textPrimary"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tvStatLowest"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lowest: —"
                                android:textColor="@color/textPrimary"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView android:id="@+id/tvStatPassing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Passing: —"
                                android:textColor="@color/colorSuccess"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tvStatFailing"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Failing: —"
                                android:textColor="@color/colorError"
                                android:textSize="13sp"
                                android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/tvStatTopStudents"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A-grade: —"
                                android:textColor="@color/textPrimary"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginVertical="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade breakdown:"
                        android:textColor="@color/textSecondary"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvGradeBreakdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A: 0  B: 0  C: 0  D: 0  F: 0"
                        android:textColor="@color/textPrimary"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STUDENT LIST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/cardStroke"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👩‍🎓  Student List"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="12dp" />

                    <!-- Empty state message -->
                    <TextView
                        android:id="@+id/tvEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No students yet.\nImport an Excel file or add students manually above."
                        android:textColor="@color/textSecondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:paddingVertical="20dp"
                        android:visibility="visible" />

                    <!-- RecyclerView — populated when students exist -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>